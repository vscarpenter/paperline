# Dependencies
node_modules/

# OS/editor files
.DS_Store
.idea/
.vscode/
*.swp

# Logs and diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build/test output
coverage/
.cache/
.vite/
.turbo/
dist/*.map

# dist/ is generated by `npm run build` but IS tracked in this repo:
# the static docs and examples load it directly, and `npm test` enforces
# parity with src/. Override any global gitignore that excludes dist/.
!dist/
!dist/**

# Local environment
.env
.env.*
!.env.example

# Package artifacts
*.tgz
