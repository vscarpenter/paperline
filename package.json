{
  "name": "paperline-design-system",
  "version": "1.0.0",
  "description": "Paperline is a warm, editorial design system for any app.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Vinny Carpenter",
    "url": "https://vinny.dev/"
  },
  "keywords": [
    "design-system",
