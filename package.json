    "./dist/paperline.css": "./dist/paperline.css",
    "./dist/components.global.jsx": "./dist/paperline-components.global.jsx",
    "./dist/icons.global.jsx": "./dist/paperline-icons.global.jsx"
  },
  "scripts": {
    "docs": "python3 -m http.server 8000",
    "test": "node scripts/check-package.mjs"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
